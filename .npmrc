# Note: Keeping these mirrors for local installs in CN is fine.
# CI (GitHub Actions) overrides mirrors via env vars in .github/workflows/release.yml
# to avoid missing assets (e.g. dmg-builder bundles).
electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
